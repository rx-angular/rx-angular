{
  "$schema": "https://json-schema.org/schema",
  "$id": "Configure",
  "title": "Configure rebundle",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "Project to configure."
    },
    "skipFormat": {
      "description": "Skip formatting files.",
      "type": "boolean",
      "default": false
    },
    "skipPackageJson": {
      "description": "Do not add dependencies to package.json.",
      "type": "boolean",
      "default": false,
      "x-priority": "internal"
    },
    "keepExistingVersions": {
      "type": "boolean",
      "x-priority": "internal",
      "description": "Keep existing dependency versions.",
      "default": false
    }
  },
  "required": ["project"]
}
