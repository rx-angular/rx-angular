{
  "$schema": "https://json-schema.org/schema",
  "$id": "Init",
  "cli": "nx",
  "title": "Initialize rebundle",
  "type": "object",
  "properties": {
    "skipFormat": {
      "description": "Skip formatting files.",
      "type": "boolean",
      "default": false
    },
    "skipPackageJson": {
      "description": "Do not add dependencies to package.json.",
      "type": "boolean",
      "default": false
    },
    "keepExistingVersions": {
      "type": "boolean",
      "x-priority": "internal",
      "description": "Keep existing dependency versions.",
      "default": false
    }
  }
}
